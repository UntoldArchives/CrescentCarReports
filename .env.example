# ─────────────────────────────────────────────────────────────
# Crescent Car Reports by Crescent Car Check — environment
# Copy to .env.local and fill in. Never commit .env.local.
# ─────────────────────────────────────────────────────────────

# Supabase
# Project URL + anon (publishable) key are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key bypasses RLS — SERVER ONLY. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_NAME=Crescent Car Reports
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Guest / demo mode — keep false in production. When true, a demo login is
# offered and demo reports never touch real data.
NEXT_PUBLIC_ENABLE_GUEST_MODE=false

# Storage bucket name for inspection photos (must match the migration).
NEXT_PUBLIC_SUPABASE_PHOTO_BUCKET=report-photos
